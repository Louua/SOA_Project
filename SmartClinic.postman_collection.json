		{
			"name": "2. GraphQL APIs",
			"item": [
				{
					"name": "Dashboard Médecin (Query)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query GetDoctorDashboard($doctorId: ID!) {\n  getDoctorDashboard(doctorId: $doctorId) {\n    doctor_name\n    appointments {\n      id\n      date\n      time\n      status\n      patient {\n        id\n        name\n        medical_history\n        heart_rate\n        temperature\n      }\n    }\n  }\n}",
								"variables": "{\n  \"doctorId\": \"d1\"\n}"
							}
						},
						"url": {
							"raw": "http://localhost:3000/graphql",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"graphql"
							]
						},
						"description": "Récupère le dashboard du médecin incluant ses rendez-vous et les données patients associées."
					},
					"response": []
