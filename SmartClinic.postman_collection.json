				{
					"name": "Mettre à jour les Constantes (Mutation)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation UpdateVitals($patientId: ID!, $heartRate: Int!, $temperature: Float!) {\n  updateVitals(patientId: $patientId, heartRate: $heartRate, temperature: $temperature) {\n    success\n    message\n  }\n}",
								"variables": "{\n  \"patientId\": \"p1\",\n  \"heartRate\": 135,\n  \"temperature\": 39.5\n}"
							}
						},
						"url": {
							"raw": "http://localhost:3000/graphql",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"graphql"
							]
						},
						"description": "Met à jour les constantes vitale d'un patient. Des valeurs élevées (ex: 135 bpm, 39.5°C) déclenchent automatiquement une alerte d'urgence dans Emergency-Service."
					},
					"response": []
				},
